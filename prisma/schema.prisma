generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model WorkspaceProfile {
  visitorId           String           @id
  plan                String           @default("free")
  stripeCustomerId    String?
  stripeSubscriptionId String?
  billingStatus       String?
  currentPeriodEnd    DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  usages              WorkspaceUsage[]

  @@index([plan])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

model WorkspaceUsage {
  visitorId      String
  periodKey      String
  auditsUsed     Int      @default(0)
  keywordsUsed   Int      @default(0)
  competitionUsed Int     @default(0)
  contentUsed    Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  profile        WorkspaceProfile @relation(fields: [visitorId], references: [visitorId], onDelete: Cascade)

  @@id([visitorId, periodKey])
  @@index([periodKey])
}

model Audit {
  id              String   @id
  manageToken     String?
  url             String
  domainNormalized String?
  isPublic        Boolean  @default(false)
  publicSlug      String?
  publicAt        DateTime?
  overallScore    Int
  seoScore        Int
  conversionScore Int
  uxScore         Int
  problems        Json
  improvements    Json
  quickWins       Json     @default("[]")
  detailedRecommendations Json @default("[]")
  copySuggestions Json     @default("{}")
  unlocked        Boolean  @default(false)
  stripeSessionId String?
  email           String?
  emailCapturedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([domainNormalized])
  @@index([publicSlug])
  @@index([isPublic, domainNormalized, createdAt])
  @@index([email])
}
