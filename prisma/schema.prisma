generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Audit {
  id              String   @id
  manageToken     String?
  url             String
  domainNormalized String?
  isPublic        Boolean  @default(false)
  publicSlug      String?
  publicAt        DateTime?
  overallScore    Int
  seoScore        Int
  conversionScore Int
  uxScore         Int
  problems        Json
  improvements    Json
  quickWins       Json     @default("[]")
  detailedRecommendations Json @default("[]")
  copySuggestions Json     @default("{}")
  unlocked        Boolean  @default(false)
  stripeSessionId String?
  email           String?
  emailCapturedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([domainNormalized])
  @@index([publicSlug])
  @@index([isPublic, domainNormalized, createdAt])
  @@index([email])
}
